{
  "manifest_version": 3,
  "name": "Exammate Helper",
  "version": "1.0.0",
  "description": "The ultimate companion for ExamMate. Cleans up UI clutter, tracks completed questions, manages favourites, and syncs your IB progress to the cloud.",
  "permissions": [
    "activeTab",
    "storage",
    "clipboardWrite",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "https://www.exam-mate.com/topicalpastpapers*",
    "https://firestore.googleapis.com/*",
    "https://openrouter.ai/*"
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.exam-mate.com/topicalpastpapers*"
      ],
      "js": [
        "src/content/content-main.js"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background/background.js"
  }
}